{
	"name": "pfefferle/atmosphere",
	"description": "Publish WordPress posts to AT Protocol (Bluesky + standard.site) via native OAuth.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Automattic",
			"homepage": "https://automattic.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"web-token/jwt-library": "^4.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^9",
		"phpcompatibility/php-compatibility": "*",
		"phpcompatibility/phpcompatibility-wp": "*",
		"squizlabs/php_codesniffer": "3.*",
		"wp-coding-standards/wpcs": "dev-develop",
		"yoast/phpunit-polyfills": "^4.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0.0",
		"sirbrillig/phpcs-variable-analysis": "^2.11",
		"phpcsstandards/phpcsextra": "^1.1.0",
		"automattic/jetpack-changelogger": "^6.0"
	},
	"autoload": {
		"classmap": [
			"includes/"
		]
	},
	"scripts": {
		"test": [
			"composer install",
			"bin/install-wp-tests.sh atmosphere-test root atmosphere-test test-db latest true",
			"vendor/bin/phpunit"
		],
		"test:wp-env": [
			"wp-env run tests-cli --env-cwd=\"wp-content/plugins/atmosphere\" vendor/bin/phpunit"
		],
		"lint": [
			"vendor/bin/phpcs"
		],
		"lint:fix": [
			"vendor/bin/phpcbf"
		],
		"changelog:add": [
			"composer install",
			"vendor/bin/changelogger add"
		],
		"changelog:write": [
			"composer install",
			"vendor/bin/changelogger write --add-pr-num"
		],
		"release": [
			"@composer install --no-dev --optimize-autoloader",
			"@composer dump-autoload --optimize --no-dev"
		]
	},
	"extra": {
		"changelogger": {
			"changes-dir": ".github/changelog/",
			"link-template": "https://github.com/Automattic/wordpress-atmosphere/compare/${old}...${new}"
		}
	},
	"config": {
		"allow-plugins": true
	}
}
